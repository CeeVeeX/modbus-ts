{
  "name": "modbus-tcp-runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "lint-staged": {
    "{apps,packages,src,test}/**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "{README.md,package.json,pnpm-workspace.yaml,tsconfig.json,tsconfig.base.json,turbo.json,.prettierrc.json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.37.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "tsdown": "^0.21.10",
    "tsdown-stale-guard": "^0.1.1",
    "tsup": "^8.5.0",
    "turbo": "^2.5.8",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  }
}
