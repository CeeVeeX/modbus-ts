{
  "name": "modbus-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "description": "A TypeScript implementation of the Modbus protocol for Node.js and browsers.",
  "author": "Cee Vee X <ceeveex@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ceeveex/modbus-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ceeveex/modbus-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ceeveex/modbus-ts/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:node-tcp-example": "pnpm --filter @modbus-ts/node-tcp-example dev",
    "dev:node-udp-example": "pnpm --filter @modbus-ts/node-udp-example dev",
    "dev:browser-example": "pnpm --filter @modbus-ts/browser-example dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "lint-staged": {
    "{apps,packages,src,test}/**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "{README.md,package.json,pnpm-workspace.yaml,tsconfig.json,tsconfig.base.json,turbo.json,.prettierrc.json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.37.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "tsdown": "^0.21.10",
    "tsdown-stale-guard": "^0.1.1",
    "tsup": "^8.5.0",
    "turbo": "^2.5.8",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  }
}
