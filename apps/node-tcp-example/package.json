{
  "name": "@modbus-ts/node-tcp-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:advanced": "tsx src/advanced.ts",
    "build": "tsup src/index.ts --format esm --target es2022 --dts --clean",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modbus-ts/client": "workspace:*",
    "@modbus-ts/transport-tcp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  }
}
