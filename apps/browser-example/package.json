{
  "name": "@modbus-ts/browser-example",
  "private": true,
  "type": "module",
  "description": "The browser-example app for modbus-ts.",
  "author": "Cee Vee X <ceeveex@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ceeveex/modbus-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ceeveex/modbus-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ceeveex/modbus-ts/issues"
  },
  "scripts": {
    "dev": "concurrently -k -n GATEWAY,WEB \"pnpm run dev:gateway\" \"pnpm run dev:web\"",
    "dev:web": "vite",
    "dev:gateway": "tsx src/gateway.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modbus-ts/client": "workspace:*",
    "@modbus-ts/codec": "workspace:*",
    "@modbus-ts/gateway": "workspace:*",
    "@modbus-ts/transport-ws": "workspace:*",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.1.7",
    "vitest": "^4.0.8"
  }
}
