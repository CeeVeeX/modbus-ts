{
  "name": "@modbus-ts/transport-udp",
  "version": "0.0.3",
  "type": "module",
  "description": "The transport-udp package for modbus-ts.",
  "author": "Cee Vee X <ceeveex@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ceeveex/modbus-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ceeveex/modbus-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ceeveex/modbus-ts/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target es2022 --dts --clean",
    "dev": "tsup src/index.ts --format esm --target es2022 --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modbus-ts/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  },
  "keywords": [
    "modbus",
    "modbus-ts",
    "transport",
    "udp",
    "datagram",
    "modbus-rtu",
    "modbus-ascii",
    "nodejs",
    "typescript",
    "esm",
    "industrial-protocol"
  ]
}
