{
  "name": "@modbus-ts/gateway",
  "version": "0.0.1",
  "type": "module",
  "description": "The gateway package for modbus-ts.",
  "author": "Cee Vee X <ceeveex@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ceeveex/modbus-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ceeveex/modbus-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ceeveex/modbus-ts/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target es2022 --dts --clean",
    "dev": "tsup src/index.ts --format esm --target es2022 --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modbus-ts/utils": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  }
}
